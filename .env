# 数据库（docker-compose 中会自动建库，这里只是确认连接串）
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=6714
PLATFORM_DATABASE_URL=mysql+aiomysql://root:root@db:3306/zscq

# 手机 WiFi IP（启动后可在前端「连接新设备」面板中输入）
PLATFORM_DEVICE_IP=

# AI 模型路径（宿主机上的路径，容器内通过 volume 挂载）
# SENSEVOICE_MODEL_DIR=/data/models/sensevoice
# PARAFORMER_MODEL_DIR=/data/models/paraformer
