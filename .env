# 本地 conda 开发配置（config.py 启动时会自动 load_dotenv）
# Docker 部署时请改用 docker-compose 注入的变量，或另建 .env.docker

MYSQL_ROOT_PASSWORD=1234
MYSQL_PORT=3306
PLATFORM_DATABASE_URL=mysql+aiomysql://root:1234@127.0.0.1:3306/zscq

# scrcpy（本机实际路径；也可留空，由 config 自动探测）
PLATFORM_SCRCPY_DIR=D:\software\scrcpy-win64-v3.3.3

# 手机 WiFi IP（AScript 显示地址；本机 LocalIP MCP 不可用时会自动回退 ADB 模式）
PLATFORM_DEVICE_IP=192.168.198.80
# 优先使用的 ADB serial（USB）；也可写 192.168.198.80:5555
PLATFORM_DEVICE_SERIAL=ZY22GQK6G6

# AI 模型路径（可选）
# SENSEVOICE_MODEL_DIR=
# PARAFORMER_MODEL_DIR=
